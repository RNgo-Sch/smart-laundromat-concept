<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_booking.xml
    Activity: BookingActivity
    Description: Screen for managing and reserving laundry machines.
                 Displays availability status and global navigation.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_off_ios"
    tools:context=".ui.activities.main.BookingActivity">


    <!-- SECTION 1: BOOKING CONTENT AREA -->
    <!-- Placeholder for machine list and reservation controls -->
    <ScrollView
        android:id="@+id/activity_booking__content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TODO: Add Washer/Dryer selection components here -->

        </LinearLayout>

    </ScrollView>

    <include
        layout="@layout/layout_location_button"/>
    <include
        layout="@layout/layout_notification"/>

    <!-- SECTION 2: GLOBAL NAVIGATION -->
    <!-- Shared bottom menu bar for app-wide routing -->
    <include
        layout="@layout/layout_menu_bar"/>

    <Button
        android:id="@+id/activity_2_1_booking_washer_button"
        android:layout_width="170dp"
        android:layout_height="70dp"

        android:layout_marginStart="30dp"

        android:layout_marginTop="100dp"
        android:background="@drawable/shape_square_box"
        android:clickable="true"
        android:drawableLeft="@drawable/ic_washer"

        android:focusable="true"
        android:fontFamily="@font/sf_pro_semibold"
        android:onClick="launchPage"

        android:text="Washer"
        android:textColor="@color/black"
        android:textSize="18dp"
        app:backgroundTint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/activity_2_1_booking_dryer_button"
        android:layout_width="170dp"
        android:layout_height="70dp"

        android:layout_marginEnd="30dp"
        android:background="@drawable/shape_square_box"


        android:clickable="true"
        android:drawableLeft="@drawable/ic_dryer"
        android:focusable="true"
        android:fontFamily="@font/sf_pro_semibold"
        android:onClick="launchPage"
        android:text="Dryer"
        android:textColor="@color/black"
        android:textSize="18dp"
        app:backgroundTint="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/activity_2_1_booking_washer_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/activity_2_1_booking_washer_button" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="300dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp">



    </androidx.constraintlayout.widget.ConstraintLayout>




</androidx.constraintlayout.widget.ConstraintLayout>

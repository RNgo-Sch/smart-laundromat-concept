<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.example.smart_laundromat_concept.ui.components.LiquidGlassView
        android:id="@+id/glass_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lg_blur_radius="5dp"
        app:lg_color="#4DFFFFFF"
        app:lg_corner_radius="30dp"
        app:lg_stroke_width="1.5dp">

        <ImageView
            android:id="@+id/glass_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_background"/>

    </com.example.smart_laundromat_concept.ui.components.LiquidGlassView>

</FrameLayout>
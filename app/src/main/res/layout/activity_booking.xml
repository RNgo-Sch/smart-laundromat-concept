<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_booking.xml
    Activity: BookingActivity
    Description: Screen for managing and reserving laundry machines.
                 Displays availability status and global navigation.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    tools:context=".ui.activities.BookingActivity">


    <!-- SECTION 1: BOOKING CONTENT AREA -->
    <!-- Placeholder for machine list and reservation controls -->
    <ScrollView
        android:id="@+id/activity_booking__content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TODO: Add Washer/Dryer selection components here -->

        </LinearLayout>

    </ScrollView>

    <include
        layout="@layout/layout_location_button"/>
    <include
        layout="@layout/layout_notification"/>


    <!-- SECTION 2: GLOBAL NAVIGATION -->
    <!-- Shared bottom menu bar for app-wide routing -->
    <include
        layout="@layout/layout_menu_bar"
        android:id="@+id/menu_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>

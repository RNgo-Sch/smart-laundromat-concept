<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDAAAA"
    tools:context=".page.BookingActivity">


    <ImageView
        android:id="@+id/activity_booking__HomeIconText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@+id/activity_booking___LinearLayout_Home"
        app:layout_constraintEnd_toEndOf="@+id/activity_booking___LinearLayout_Home"
        app:layout_constraintStart_toStartOf="@+id/activity_booking___LinearLayout_Home"
        app:layout_constraintTop_toTopOf="@+id/activity_booking___LinearLayout_Home"
        app:layout_constraintVertical_bias="0.39"
        app:srcCompat="@drawable/shape_menu_select" />

    <ImageView
        android:id="@+id/activity_booking__BookingIconText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/shape_menu_select"
        app:layout_constraintBottom_toBottomOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintEnd_toEndOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintStart_toStartOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintTop_toTopOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintVertical_bias="0.39"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/activity_booking___ProfileIconText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/shape_menu_select"
        app:layout_constraintBottom_toBottomOf="@+id/activity_booking___LinearLayout_Profile"
        app:layout_constraintEnd_toEndOf="@+id/activity_booking___LinearLayout_Profile"
        app:layout_constraintStart_toStartOf="@+id/activity_booking___LinearLayout_Profile"
        app:layout_constraintTop_toTopOf="@+id/activity_booking___LinearLayout_Profile"
        app:layout_constraintVertical_bias="0.39"
        android:visibility="visible" />


    <LinearLayout
        android:id="@+id/activity_booking___LinearLayout_Booking"
        android:layout_width="150dp"
        android:layout_height="90dp"
        android:layout_marginBottom="-8dp"
        android:clickable="true"
        android:onClick="launchPage"
        android:focusable="true"

        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/activity_booking__Menu_Bar"
        app:layout_constraintEnd_toEndOf="@+id/activity_booking__Menu_Bar"
        app:layout_constraintStart_toStartOf="@+id/activity_booking__Menu_Bar"
        app:layout_constraintTop_toTopOf="@+id/activity_booking__Menu_Bar">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:srcCompat="@drawable/ic_booking" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-8dp"
            android:fontFamily="@font/sf_pro_semibold"
            android:text="Booking"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/activity_booking___LinearLayout_Profile"
        android:layout_width="150dp"
        android:layout_height="90dp"
        android:layout_marginStart="-20dp"
        android:clickable="true"
        android:onClick="launchPage"
        android:focusable="true"

        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintStart_toEndOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintTop_toTopOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintVertical_bias="0.0">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:srcCompat="@drawable/ic_profile" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-8dp"
            android:fontFamily="@font/sf_pro_semibold"
            android:text="Profile"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/activity_booking__Menu_Bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:layout_marginBottom="55dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/shape_menu_bar" />

    <LinearLayout
        android:id="@+id/activity_booking___LinearLayout_Home"
        android:layout_width="150dp"
        android:layout_height="90dp"
        android:layout_marginEnd="-20dp"
        android:clickable="true"
        android:focusable="true"

        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintEnd_toStartOf="@+id/activity_booking___LinearLayout_Booking"
        app:layout_constraintTop_toTopOf="@+id/activity_booking___LinearLayout_Booking">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:srcCompat="@drawable/ic_house"
            app:tint="@color/blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:fontFamily="@font/sf_pro_semibold"
            android:text="Home"
            android:textColor="@color/blue"
            android:textSize="14sp"
            tools:layout_editor_absoluteX="82dp"
            tools:layout_editor_absoluteY="423dp" />
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>

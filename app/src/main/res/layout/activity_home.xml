<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_home.xml
    Activity: HomeActivity
    Description: Main landing dashboard for the application after successful login.
                 Contains the primary app features and global navigation.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_home__root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_off_ios"
    tools:context=".ui.activities.main.HomeActivity">


    <!-- ── Scrollable content ─────────────────────────────────────────── -->
    <!--
        Top is pinned to PARENT top (not the location include — that has
        layout_height="match_parent" so its bottom is off-screen).
        paddingTop="80dp" on the inner LinearLayout provides the visual
        gap that clears the floating location/notification bar.
        clipToPadding="false" lets the top padding area show the background
        rather than clipping it white.
    -->

    <!-- ── Floating overlays — declared AFTER ScrollView so they draw on top ── -->
    <ScrollView
        android:id="@+id/activity_home__scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="10dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- ── Smart Status Card (snapshot ↔ active booking) ────── -->
            <include
                android:id="@+id/activity_home__status_card"
                layout="@layout/layout_home_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp" />

            <!-- ── Reputation Card ──────────────────────────────────── -->
            <include
                layout = "@layout/layout_reputation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"/>


            <!-- ── Wallet Card ──────────────────────────────────────── -->
            <include
                layout = "@layout/layout_wallet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="200dp"/>




        </LinearLayout>


    </ScrollView>

    <include
        android:id="@+id/location"
        layout="@layout/layout_location_button"/>
    <include layout="@layout/layout_notification"/>

    <!-- ── Bottom navigation bar ─────────────────────────────────────── -->
    <include
        android:id="@+id/menu_bar"
        layout="@layout/layout_menu_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_home.xml
    Activity: HomeActivity
    Description: Main landing dashboard for the application after successful login.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_home__root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_off_ios"
    tools:context=".ui.activities.main.HomeActivity">


    <!-- ── Scrollable content ─────────────────────────────────────────── -->
    <!--
        Top is pinned to PARENT top (not the location include — that has
        layout_height="match_parent" so its bottom is off-screen).
        paddingTop="80dp" on the inner LinearLayout provides the visual
        gap that clears the floating location/notification bar.
        clipToPadding="false" lets the top padding area show the background
        rather than clipping it white.
    -->

    <!-- ── Floating overlays — declared AFTER ScrollView so they draw on top ── -->
    <ScrollView
        android:id="@+id/activity_home__scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="10dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- ── Smart Status Card (snapshot ↔ active booking) ────── -->
            <include
                android:id="@+id/activity_home__status_card"
                layout="@layout/layout_home_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />

            <!-- ── Reputation Card ──────────────────────────────────── -->
            <include
                layout = "@layout/layout_reputation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"/>


            <!-- ── Wallet Card ──────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/activity_home__wallet_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="200dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/sf_pro_semibold"
                        android:text="My Wallet"
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:text="$"
                            android:textColor="@color/blue"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/activity_home__wallet_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:text="120.50"
                            android:textColor="@color/black"
                            android:textSize="32sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/activity_home__wallet_top_up"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:paddingBottom="4dp"
                            android:text="Top Up"
                            android:textColor="@color/blue"
                            android:textSize="15sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>



        </LinearLayout>

    </ScrollView>

    <include
        android:id="@+id/location"
        layout="@layout/layout_location_button"/>
    <include layout="@layout/layout_notification"/>

    <!-- ── Bottom navigation bar ─────────────────────────────────────── -->
    <include
        android:id="@+id/menu_bar"
        layout="@layout/layout_menu_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
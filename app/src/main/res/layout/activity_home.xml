<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_home.xml
    Activity: HomeActivity
    Description: Main landing dashboard for the application after successful login.
                 Contains the primary app features and global navigation.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_home__root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_background_dark"
    tools:context=".ui.activities.HomeActivity">


    <!-- SECTION 1: MAIN CONTENT AREA -->
    <!-- Placeholder for home screen content -->
    <ScrollView
        android:id="@+id/activity_home__content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/menu_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TODO: Add Home Dashboard components here -->

        </LinearLayout>

    </ScrollView>


    <!-- SECTION 2: GLOBAL NAVIGATION -->
    <!-- Shared bottom menu bar for app-wide routing -->
    <include
        layout="@layout/menu_bar"
        android:id="@+id/menu_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>

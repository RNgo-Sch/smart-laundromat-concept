<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_home.xml
    Activity: HomeActivity
    Description: Main landing dashboard for the application after successful login.
                 Contains the primary app features and global navigation.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_home__root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_off_ios"
    tools:context=".ui.activities.main.home.HomeActivity">

    <!-- ── Swipe to refresh + Scrollable content ─────────────────────── -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/activity_home__swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/activity_home__scroll_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="10dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <!-- ── Smart Status Card (snapshot ↔ active booking) ── -->
                <include
                    android:id="@+id/activity_home__status_card"
                    layout="@layout/layout_home_status_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" />

                <!-- ── Reputation Card ──────────────────────────────── -->
                <include
                    layout="@layout/layout_reputation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" />

                <!-- ── Wallet Card ──────────────────────────────────── -->
                <include
                    layout="@layout/layout_wallet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" />

                <!-- Bottom spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />

            </LinearLayout>

        </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ── Floating overlays — declared AFTER SwipeRefreshLayout so they draw on top ── -->
    <include
        android:id="@+id/location"
        layout="@layout/layout_location_button" />

    <include layout="@layout/layout_notification" />

    <!-- ── Bottom navigation bar ─────────────────────────────────────── -->
    <include
        android:id="@+id/menu_bar"
        layout="@layout/layout_menu_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <FrameLayout
        android:id="@+id/activity_home__Reputation_Details"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:onClick="launchPage">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="30dp">

            <!-- Confirmation Glass Card -->
            <include
                android:id="@+id/activity_profile__confirmation_glass"
                layout="@layout/layout_container"
                android:layout_width="match_parent"
                android:layout_height="250dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reputation Details"
                    android:textColor="@color/black"
                    android:textSize="25sp"
                    android:fontFamily="@font/sf_pro_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/reputation_logic"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:fontFamily="@font/sf_pro_semibold" />


                <TextView
                    android:id="@+id/activity_home__cancel_Reputation_Details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:text="Click anywhere to close"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:clickable="true"
                    android:onClick="launchPage"
                    android:focusable="true"/>

            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: layout_home_active_booking.xml
    Description: Shown when the user has a currently running machine cycle.
                 Displays machine label, status, a live countdown, and a
                 shortcut button to the Booking screen.
                 Populated by HomeCardHelper.bindActiveBooking().
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Machine name, e.g. "Washer 2" -->
    <TextView
        android:id="@+id/active__machine_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Washer 2"
        android:textSize="22sp"
        android:fontFamily="@font/sf_pro_bold"
        android:textColor="@color/black" />

    <!-- Status badge -->
    <TextView
        android:id="@+id/active__status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="In Progress"
        android:textSize="14sp"
        android:fontFamily="@font/sf_pro_semibold"
        android:textColor="@color/blue" />

    <!-- Live countdown, e.g. "14:32" -->
    <TextView
        android:id="@+id/active__timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:text="--:--"
        android:textSize="52sp"
        android:fontFamily="@font/sf_pro_bold"
        android:textColor="@color/black" />

    <!-- Shortcut to Booking screen -->
    <Button
        android:id="@+id/active__view_details"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="View Booking"
        android:backgroundTint="@color/blue"
        android:fontFamily="@font/sf_pro_bold"
        android:textColor="@color/white"
        android:onClick="launchPage"
        app:cornerRadius="25dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>

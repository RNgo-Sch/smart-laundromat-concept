<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_background"
    tools:context="page.MainActivity">

    <!-- Stacking the blur and the content using FrameLayout -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="30dp">


        <com.example.smart_laundromat_concept.classes.LiquidGlassView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_box1"
            app:lg_blur_radius="10000dp"
            app:lg_color="#4DFFFFFF"
            app:lg_corner_radius="30dp" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_horizontal"
            android:padding="26dp">

            <!-- Loging text -->
            <TextView
                android:id="@+id/login_signup__loginSignup_Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Login/Signup"
                android:textSize="36sp"
                android:textAlignment="center"
                android:textStyle="bold"
                android:fontFamily="@font/sf_pro_bold"
                android:textColor="@color/blue"/>

            <!-- Username input -->
            <EditText
                android:id="@+id/login_signup__username_text"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_box1"
                android:backgroundTint="#4D000000"
                android:drawableLeft="@drawable/ic_user"
                android:drawablePadding="8dp"
                android:hint="Username"
                android:inputType="text"
                android:padding="8dp"
                android:textColor="@color/black"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColorHighlight="@color/cardview_dark_background" />

            <!-- Password input -->
            <EditText
                android:id="@+id/activity_main__password_text"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/shape_box1"
                android:drawableLeft="@drawable/ic_lock"
                android:backgroundTint="#4D000000"
                android:drawablePadding="8dp"
                android:hint="Password"
                android:padding="8dp"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColorHighlight="@color/cardview_dark_background"
                android:layout_marginTop="20dp"/>

            <!-- Login button -->
            <Button
                android:id="@+id/activity_main__login_Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="@color/blue"
                android:fontFamily="@font/sf_pro_semibold"
                android:onClick="launchPage"
                android:text="Login"
                android:textSize="18sp"
                app:cornerRadius="30dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- go to sign up page -->
    <Button
        android:id="@+id/activity_main__go_to_signup_Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="@android:color/transparent"
        app:backgroundTint="@android:color/transparent"
        app:elevation="0dp"
        android:stateListAnimator="@null"
        android:onClick="launchPage"
        android:padding="8dp"
        android:text="@string/Ask_Signup"
        android:fontFamily="@font/sf_pro_semibold"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textAllCaps="false"/>

</LinearLayout>

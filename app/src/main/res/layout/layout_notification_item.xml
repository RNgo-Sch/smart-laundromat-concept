<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginHorizontal="20dp"
    android:layout_marginTop="10dp">

    <include
        layout="@layout/layout_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Type label e.g. "Booking", "Collect laundry" -->
        <TextView
            android:id="@+id/notification_item__type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sf_pro_bold"
            android:layout_marginTop="-10dp"
            android:textColor="@color/blue"
            android:text="Announcement"
            android:textSize="20sp" />

        <!-- Notification message -->
        <TextView
            android:id="@+id/notification_item__message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:fontFamily="@font/sf_pro_semibold"
            android:textColor="@color/black"
            android:text="Laundromat will be closed on 25 Dec 2026."
            android:textSize="18sp" />

        <!-- Timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/notification_item__time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:fontFamily="@font/sf_pro_semibold"

                android:textColor="#888888"
                android:text="2026-03-21T06:57.23.43112"
                android:textSize="14sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/sf_pro_semibold"
                android:text="Details"
                android:textColor="#888888"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_arrow_right"
                android:contentDescription="@null"
                app:tint="#888888" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
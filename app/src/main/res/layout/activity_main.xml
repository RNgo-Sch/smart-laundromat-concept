<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_background">

    <!-- Stacking the blur and the content using FrameLayout -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="354dp"
        android:layout_margin="30dp">


        <include
            layout="@layout/glass_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <!-- The Sharp Outline (Drawn on top of the blur) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/glass_shape" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="26dp">

            <!-- Title text (Login/Signup) -->
            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:srcCompat="@drawable/dryerlogo" />

            <!-- Username input -->
            <EditText
                android:id="@+id/activity_main__username_text"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_box1"
                android:backgroundTint="#4D000000"
                android:drawableLeft="@drawable/ic_user"
                android:drawablePadding="8dp"
                android:fontFamily="@font/sf_pro_semibold"
                android:hint="Username"
                android:inputType="text"
                android:padding="8dp"
                android:textColor="@color/black" />

            <!-- Password input -->
            <EditText
                android:id="@+id/activity_main__password_text"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_box1"
                android:backgroundTint="#4D000000"
                android:drawableLeft="@drawable/ic_lock"
                android:drawablePadding="8dp"
                android:fontFamily="@font/sf_pro_semibold"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="8dp"
                android:textColor="@color/black" />

            <!-- Action button (Login/Create Account) -->
            <Button
                android:id="@+id/activity_main__login_Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="@color/blue"
                android:fontFamily="@font/sf_pro_semibold"
                android:onClick="launchPage"
                android:text="Login"
                android:textSize="18sp"
                app:cornerRadius="30dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- Switch button (Don't have an account?/Return to Login) -->
    <Button
        android:id="@+id/activity_main__go_to_signup_Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="@android:color/transparent"
        app:backgroundTint="@android:color/transparent"
        app:elevation="0dp"
        android:stateListAnimator="@null"
        android:onClick="launchPage"
        android:padding="8dp"
        android:text="Don't have an account? Sign Up"
        android:fontFamily="@font/sf_pro_semibold"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textAllCaps="false"/>

</LinearLayout>

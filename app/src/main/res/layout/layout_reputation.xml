<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: layout_reputation.xml
    Description: Displays the user's reputation tier and progress.
                 Uses a glassmorphism container as a background.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_home__tier_card_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Reusable Glass Background -->
    <include
        layout="@layout/layout_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Reputation Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/reputation__tier_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sf_pro_semibold"
            android:text="Reputation: Tier 4"
            android:textColor="@color/red"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:text="Orders"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/reputation__progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:text="65/100"
                    android:textColor="@color/red"
                    android:textSize="22sp" />

                <ProgressBar
                    android:id="@+id/reputation__progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="65"
                    android:progressBackgroundTint="#DDDDDD"
                    android:progressTint="@color/red" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/reputation__refresh_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/sf_pro_semibold"
                android:text="Progress will be refreshed on 30.06.2026"
                android:textColor="#888888"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/sf_pro_semibold"
                android:text="Details"
                android:textColor="#888888"
                android:textSize="12sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_arrow_right"
                android:contentDescription="@null"
                app:tint="#888888" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
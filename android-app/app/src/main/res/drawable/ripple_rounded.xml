<?xml version="1.0" encoding="utf-8"?>
<!--
    Drawable: ripple_rounded.xml
    Description: A ripple effect constrained to a rounded rectangle mask.
                 Used for buttons and interactive list items with rounded corners.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#20000000">

    <!-- The mask defines the shape of the ripple effect -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <solid android:color="@android:color/white" />
        </shape>
    </item>

</ripple>

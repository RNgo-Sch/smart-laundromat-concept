<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: layout_home_snapshot.xml
    Description: Shows a quick summary of washer and dryer availability.
                 Populated by HomeCardHelper.loadMachineSnapshot().
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Machine Availability"
        android:textSize="18sp"
        android:fontFamily="@font/sf_pro_bold"
        android:textColor="@color/black"
        android:layout_marginBottom="10dp" />

    <!-- ── Washers Row ───────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Washers"
        android:textSize="14sp"
        android:fontFamily="@font/sf_pro_semibold"
        android:textColor="#888888"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <!-- Available -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/shape_container_square"
            android:backgroundTint="@color/green_50_visibility"
            android:padding="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/snapshot__washer_available"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:fontFamily="@font/sf_pro_bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available"
                android:textSize="12sp"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- In Use -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/shape_container_square"
            android:backgroundTint="@color/red_50_visibility"
            android:padding="12dp">

            <TextView
                android:id="@+id/snapshot__washer_in_use"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:fontFamily="@font/sf_pro_bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Use"
                android:textSize="12sp"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="#888888" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Dryers Row ────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dryers"
        android:textSize="14sp"
        android:fontFamily="@font/sf_pro_semibold"
        android:textColor="#888888"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Available -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/shape_container_square"
            android:backgroundTint="@color/green_50_visibility"
            android:padding="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/snapshot__dryer_available"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:fontFamily="@font/sf_pro_bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available"
                android:textSize="12sp"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- In Use -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/shape_container_square"
            android:backgroundTint="@color/red_50_visibility"
            android:padding="12dp">

            <TextView
                android:id="@+id/snapshot__dryer_in_use"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:fontFamily="@font/sf_pro_bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Use"
                android:textSize="12sp"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="#888888" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

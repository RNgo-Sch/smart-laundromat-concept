<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="30dp"
    android:layout_marginTop="20dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- shape and color -->
    <include
        android:id="@+id/activity_profile__logout_glass_include"
        layout="@layout/layout_container"
        android:layout_width="match_parent"
        android:layout_height="56dp" />

    <!-- Interactive Logout Item - button -->
    <RelativeLayout
        android:id="@+id/layout_button__btn__button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/ripple_rounded"
        android:clickable="true"
        android:focusable="true"
        android:onClick="launchPage">


        <TextView
            android:id="@+id/layout_button__tv__text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:fontFamily="@font/sf_pro_bold"
            android:gravity="center"
            android:text="Button"
            android:textColor="@color/black"
            android:textSize="17sp" />

    </RelativeLayout>

</FrameLayout>

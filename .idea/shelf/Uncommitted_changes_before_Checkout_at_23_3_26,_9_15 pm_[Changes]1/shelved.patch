+    /**
+     * Loads machine states from Supabase based on the currently selected location.
+     */
+    private void loadMachineStates() {
+        int storeNumber = getStoreNumber();
+
+        SupabaseClient.getApi()
+                .getMachineByStoreType(storeNumber, "washer")
+                .enqueue(new Callback<List<Machine>>() {
+                    @Override
+                    public void onResponse(Call<List<Machine>> call, Response<List<Machine>> response) {
+                        if (response.isSuccessful() && response.body() != null) {
+                            applyMachineStates(response.body(), washerManager);
+                        }
+                    }
+                    @Override
+                    public void onFailure(Call<List<Machine>> call, Throwable t) {}
+                });
+
+        SupabaseClient.getApi()
+                .getMachineByStoreType(storeNumber, "dryer")
+                .enqueue(new Callback<List<Machine>>() {
+                    @Override
+                    public void onResponse(Call<List<Machine>> call, Response<List<Machine>> response) {
+                        if (response.isSuccessful() && response.body() != null) {
+                            applyMachineStates(response.body(), dryerManager);
+                        }
+                    }
+                    @Override
+                    public void onFailure(Call<List<Machine>> call, Throwable t) {}
+                });
+    }
+
+    /**
+     * Maps Supabase status strings to MachineStateHelper constants.
+     *
+     * @param machines list of machines from Supabase
+     * @param manager  the WasherManager or DryerManager to update
+     */
+    private void applyMachineStates(List<Machine> machines, Object manager) {
+        for (int i = 0; i < machines.size(); i++) {
+            int machineNum = i + 1;
+            int state = statusToState(machines.get(i).getCurStatus());
+
+            if (manager instanceof WasherManager) {
+                ((WasherManager) manager).setState(machineNum, state);
+            } else if (manager instanceof DryerManager) {
+                ((DryerManager) manager).setState(machineNum, state);
+            }
+        }
+    }
+
+    /**
+     * Converts a Supabase status string to a MachineStateHelper constant.
+     *
+     * @param status the raw status string from Supabase
+     * @return the matching state constant
+     */
+    private int statusToState(String status) {
+        if (status == null) return MachineStateHelper.STATE_OPEN;
+        switch (status) {
+            case "in_use":         return MachineStateHelper.STATE_IN_USE;
+            case "reserved":       return MachineStateHelper.STATE_RESERVED;
+            case "collection":     return MachineStateHelper.STATE_COLLECTION;
+            case "out_of_service": return MachineStateHelper.STATE_OUT_OF_SERVICE;
+            case "open":
+            default:               return MachineStateHelper.STATE_OPEN;
+        }
+    }
+
+    /**
+     * Returns the Supabase store number for the currently selected location.
+     *
+     * @return store number matching the location
+     */
+    private int getStoreNumber() {
+        String locationName = LocationSession.getInstance().getLocationName();
+        switch (locationName) {
+            case "SUTD Blk 57": return 2;
+            case "SUTD Blk 55": return 3;
+            case "SUTD Blk 59":
+            default:            return 1;
+        }
+    }
